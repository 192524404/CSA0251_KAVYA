#include<stdio.h>
void main() {
    int n, sq, temp;
    scanf("%d", &n);
    sq = n * n;
    temp = n;
    while(temp > 0) {
        if(temp % 10 != sq % 10) {
            printf("Not Automorphic");
            return;
        }
        temp = temp / 10;
        sq = sq / 10;
    }
    printf("Automorphic Number");
}
