#include <stdio.h>
int main() {
    int n,num,digit,sum=0;
    printf("Enter an integer: ");
    scanf("%d", &n);
    num=n;
    while (n != 0) {
        digit = n % 10;          
        sum+=digit*digit*digit;
        n /= 10;    
    }
    if(num==sum)
    printf("armstrong number");
    else
    printf("not an armstrong number");
    return 0;
}
