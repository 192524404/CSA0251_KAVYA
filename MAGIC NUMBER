#include <stdio.h>
void main() {
    int num, temp, digit, sum;
    scanf("%d", &num);
    temp = num;
    while(temp > 9) {
        sum = 0;
        while(temp > 0) {
            digit = temp % 10;
            sum = sum + digit;
            temp = temp / 10;
        }
        temp = sum;
    }
    if(temp == 1)
        printf("Magic Number");
    else
        printf("Not a Magic Number");
}
