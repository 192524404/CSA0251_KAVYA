#include <stdio.h>
int main() 
{
    int n, a = 0, b = 1, c, i = 1;
    scanf("%d", &n);
    printf("EVEN FIBONACCI SERIES:\n");

    while (i <= n) 
    {
        if (a % 2 == 0)
        {
            printf("%d\n ", a);
        }
        c = a + b;
        a = b;
        b = c;
        i++;
    }
    return 0;
}
