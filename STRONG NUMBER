#include <stdio.h>
void main() {
    int num, temp, digit, i, fact, sum = 0;
    scanf("%d", &num);
    temp = num;
    while(temp > 0) {
        digit = temp % 10;
        fact = 1;
        for(i = 1; i <= digit; i++) {
            fact = fact * i;
        }
        sum = sum + fact;
        temp = temp / 10;
    }
    if(sum == num)
        printf("Strong Number");
    else
        printf("Not a Strong Number");
}
