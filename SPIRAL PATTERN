#include <stdio.h>
void main() {
    int a[10][10];
    int n = 4;
    int top = 0, bottom = n - 1;
    int left = 0, right = n - 1;
    int num = 1;
    int i, j;
    while(top <= bottom && left <= right) {
        for(i = left; i <= right; i++) {
            a[top][i] = num++;
        }
        top++;
        for(i = top; i <= bottom; i++) {
            a[i][right] = num++;
        }
        right--;
        for(i = right; i >= left; i--) {
            a[bottom][i] = num++;
        }
        bottom--;
        for(i = bottom; i >= top; i--) {
            a[i][left] = num++;
        }
        left++;
    }
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            printf("%3d", a[i][j]);
        }
        printf("\n");
    }
}
