#include <stdio.h>
int main() {
    int rows = 4; 
    for (int i = 1; i <= rows; i++) {
        for (int j = 1; j <= (rows - i); j++) {
            printf(" ");
        }
        for (int j = 1; j <= (2 * i - 1); j++) {
            if (j == 1 || j == (2 * i - 1) || i == rows) {
                printf("*");
            } else {
                printf(" ");
            }
        }
        printf("\n");
    }
    return 0;
}
